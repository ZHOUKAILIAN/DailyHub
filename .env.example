# ---------------------------
# DailyHub global
# ---------------------------
DAILYHUB_LOG_LEVEL=INFO
DAILYHUB_HTTP_TIMEOUT_SECONDS=30
DAILYHUB_HTTP_RETRIES=3
DAILYHUB_HTTP_BACKOFF_SECONDS=1
DAILYHUB_HTTP_BACKOFF_FACTOR=2

# ---------------------------
# Xiaoju Charging (required auth)
# Capture ticket/token/token_id and am_did from real app traffic (e.g. Charles proxy)
# ---------------------------
DAILYHUB_XIAOJU_TICKET=
DAILYHUB_XIAOJU_TOKEN=
DAILYHUB_XIAOJU_TOKEN_ID=
DAILYHUB_XIAOJU_APP_ID=121358
DAILYHUB_XIAOJU_AM_CHANNEL=1323124385
DAILYHUB_XIAOJU_SOURCE=1323124385
DAILYHUB_XIAOJU_TTID=driver

# ---------------------------
# Xiaoju Charging (optional runtime)
# ---------------------------
DAILYHUB_XIAOJU_BASE_URL=https://energy.xiaojukeji.com
DAILYHUB_XIAOJU_BIZ_LINE=250
DAILYHUB_XIAOJU_CITY_ID=5
DAILYHUB_XIAOJU_AM_TTID=10001@xjcd_android_1.8.7_1201080701
# REQUIRED: unique device fingerprint per account — capture from real app traffic.
# Do NOT share this value across accounts; identical am_did values trigger anti-fraud linkage.
DAILYHUB_XIAOJU_AM_DID=
DAILYHUB_XIAOJU_AM_DINFO=google-sdk_gphone64_arm64@16@1080
DAILYHUB_XIAOJU_APP_VERSION=1.8.7
DAILYHUB_XIAOJU_AM_LANG=en
DAILYHUB_XIAOJU_AM_FS=10001
DAILYHUB_XIAOJU_AM_NET=WIFI
DAILYHUB_XIAOJU_AM_NQ=WIFI
