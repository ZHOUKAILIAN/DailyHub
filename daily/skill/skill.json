{
  "name": "morning-orchestrator",
  "display_name": "Morning Orchestrator",
  "version": "1.2.0",
  "description": "Morning automation entry point. Registers one cron job per task in the schedule table. Each job fires at its specified time and invokes the corresponding skill.",
  "entry": "SKILL.md",
  "task_type": "orchestration",
  "platform": "ai-morning",
  "triggers": [
    "run morning routine",
    "start morning automation",
    "run all morning tasks",
    "morning orchestrator",
    "morning overall"
  ],
  "requires_env": [
    "DAILYHUB_XIAOJU_TICKET",
    "DAILYHUB_XIAOJU_TOKEN",
    "DAILYHUB_XIAOJU_TOKEN_ID"
  ],
  "sub_skills": [
    "checkin/xiaojuchongdian/skill/overall",
    "routine/ai-morning/skill/ai-daily-news-and-changelog"
  ]
}
